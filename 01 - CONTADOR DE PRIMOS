#include <stdio.h>

int primoounao(int numero) {
    int divisores = 0, primosimnao, i;
    
    for(i = 1; i <= numero; i++ ) {
        if(numero % i == 0)
        divisores++;
    } 
    
        if(divisores == 2) 
        primosimnao = 1;
        else
        primosimnao = 0;
        
    return primosimnao;
}

