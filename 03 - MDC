#include <stdio.h>

int main()  {
    int numero1, numero2, divisores1, divisores2, mdc, i;
    
    do{
        
        printf("ME INFORME DOIS NUMERO INTEIRO POSITIVO: ");
        scanf("%d%d", &numero1, &numero2);
    
    }while(numero1 < 0 || numero2 < 0);
    
    for(i = 1; i <= numero1; i++) {
        if(numero1 % i == 0)
            divisores1 = i;
        
        if(numero2 % i == 0)
            divisores2 = i;
            
        if(divisores1 == divisores2)
            mdc = divisores1;
    }
    
    printf("\nMDC: %d", mdc);
    
    return 0;
}
