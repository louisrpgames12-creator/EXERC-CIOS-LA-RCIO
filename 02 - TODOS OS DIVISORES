    int numero, i;
    
    do{
            printf("ME INFORME UM NUMERO INTEIRO POSITIVO: ");
            scanf("%d", &numero);
    }while(numero < 0);
    
    for(i = 1; i <=numero; i++) {
        
        if(numero % i == 0)
        printf("%d ", i);
    }


