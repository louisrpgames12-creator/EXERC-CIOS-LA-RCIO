#include <stdio.h>

int main()  {
    int i, j, divisores = 0;
    
    for(i = 1000; i < 2000; i++) {
        for(j = 1; j <= i; j++) {
            if(i % j == 0)
            divisores++;
        }
        
        if(divisores == 2)
        printf("%d\n", i);
        divisores = 0;
    }

    return 0;
}
